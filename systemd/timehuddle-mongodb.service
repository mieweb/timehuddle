[Unit]
Description=MongoDB (TimeHuddle)
After=network.target
Documentation=https://www.mongodb.com

[Service]
Type=forking
PIDFile=/var/run/mongod.pid
ExecStart=/usr/bin/mongod \
    --fork \
    --logpath /var/log/mongodb.log \
    --dbpath /data/db \
    --bind_ip 127.0.0.1 \
    --port 27017 \
    --replSet rs0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
