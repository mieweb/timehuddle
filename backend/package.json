{
  "name": "timeharbor-timehuddle-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "start": "node dist/server.js",
    "migrate": "npx migrate-mongo up -f migrate-mongo-config.cjs",
    "migrate:status": "npx migrate-mongo status -f migrate-mongo-config.cjs",
    "migrate:down": "npx migrate-mongo down -f migrate-mongo-config.cjs",
    "seed": "tsx scripts/seed.ts",
    "seed:hierarchy": "tsx scripts/seed-org-hierarchy.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.2",
    "@better-auth/core": "^1.6.9",
    "@casl/ability": "^6.8.1",
    "@casl/mongoose": "^8.0.5",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@mieweb/pulsevault": "^0.0.2",
    "@noble/ciphers": "^2.2.0",
    "@parse/node-apn": "^7.1.0",
    "@timehuddle/youtube": "*",
    "agenda": "^6.2.5",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.2.8",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "firebase-admin": "^13.0.0",
    "jose": "^6.2.3",
    "mongodb": "^6.14.2",
    "mongoose": "^9.6.2",
    "nodemailer": "^8.0.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "migrate-mongo": "^14.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
