{
  "name": "timeharbor-timehuddle-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "better-auth": "^1.2.8",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "mongodb": "^6.14.2",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
