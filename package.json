{
  "name": "timehuddle",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prune:legacy": "bash ./scripts/prune-legacy.sh --yes",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "npm test --prefix packages/youtube && vitest run && npm test --prefix backend",
    "test:watch": "vitest",
    "screenshots": "npx playwright test e2e/screenshots.spec.ts",
    "prepare": "node scripts/prepare-husky.cjs",
    "dev:mobile": "vite --host",
    "dev:ios": "bash scripts/dev-ios.sh",
    "testflight:ios": "vite build --mode testflight && npx cap sync ios && npx cap open ios",
    "prod:ios": "vite build --mode production && npx cap sync ios && npx cap open ios",
    "dev:android": "vite build --mode capacitor.dev && npx cap sync && npx cap open android",
    "prod:android": "vite build --mode production && npx cap sync && npx cap open android"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@fortawesome/fontawesome-free": "^7.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.0.1",
    "@fortawesome/free-regular-svg-icons": "^7.0.1",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@fortawesome/react-fontawesome": "^3.0.2",
    "@mieweb/ui": "^0.2.4",
    "@mieweb/ychart": "^1.1.0",
    "@swc/helpers": "^0.5.17",
    "motion": "^12.34.3",
    "postcss-load-config": "^6.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/oxide": "4.1.13",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "husky": "^9.1.6",
    "jsdom": "^29.1.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-refresh": "^0.17.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
