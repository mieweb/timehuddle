{
  "name": "timehuddle",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prune:legacy": "bash ./scripts/prune-legacy.sh --yes",
    "migrate": "node scripts/migrate-complete.mjs",
    "migrate:dry-run": "node scripts/migrate-complete.mjs --dry-run",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test -c tests/playwright.config.ts",
    "test:headed": "playwright test -c tests/playwright.config.ts --headed",
    "test:ui": "playwright test -c tests/playwright.config.ts --ui",
    "test:unit": "vitest run",
    "test:e2e": "playwright test -c tests/playwright.config.ts",
    "test:e2e:headed": "playwright test -c tests/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test -c tests/playwright.config.ts --ui",
    "test:all": "npm run test:unit && npm run test",
    "test:watch": "vitest",
    "prepare": "node scripts/prepare-husky.cjs",
    "dev:mobile": "vite --host",
    "dev:ios": "bash scripts/dev-ios.sh",
    "testflight:ios": "CAPACITOR=1 vite build --mode testflight && npx cap sync ios && npx cap open ios",
    "prod:ios": "CAPACITOR=1 vite build --mode production && npx cap sync ios && npx cap open ios",
    "dev:android": "bash scripts/dev-android.sh",
    "testflight:android": "CAPACITOR=1 vite build --mode testflight && npx cap sync android && npx cap open android",
    "prod:android": "CAPACITOR=1 vite build --mode production && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@fortawesome/fontawesome-free": "^7.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.0.1",
    "@fortawesome/free-regular-svg-icons": "^7.0.1",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@fortawesome/react-fontawesome": "^3.0.2",
    "@kerebron/editor": "^0.7.9",
    "@kerebron/extension-automerge": "^0.2.1",
    "@kerebron/extension-basic-editor": "^0.7.9",
    "@mieweb/ui": "^0.2.4",
    "@mieweb/ychart": "^1.1.0",
    "@swc/helpers": "^0.5.17",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "motion": "^12.34.3",
    "postcss-load-config": "^6.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tus-js-client": "^4.3.1",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/oxide": "4.1.13",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/tus-js-client": "^1.8.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "bcrypt": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "husky": "^9.1.6",
    "jsdom": "^29.1.0",
    "lint-staged": "^15.2.10",
    "mongodb": "^7.5.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-refresh": "^0.17.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5",
    "ws": "^8.21.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
